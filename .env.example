# AWS RDS PostgreSQL Configuration
# Copy this file to .env and fill in your values

AWS_RDS_HOST=pnl-db.cbukkwwqer7w.ap-southeast-1.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_DATABASE=postgres
AWS_RDS_USER=postgres
AWS_RDS_PASSWORD=your_password_here

# Set to "false" to use parquet files instead of database
USE_DATABASE=true
